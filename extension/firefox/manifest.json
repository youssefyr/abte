{
  "manifest_version": 2,
  "name": "abte Bridge",
  "version": "0.2.0",
  "description": "Secure focus assistant bridge for abte (Firefox).",
  "permissions": [
    "tabs",
    "activeTab",
    "nativeMessaging",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "abte",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "abte-bridge@zyroo.com",
      "strict_min_version": "91.0"
    }
  }
}